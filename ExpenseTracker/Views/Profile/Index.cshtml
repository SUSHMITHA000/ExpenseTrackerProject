@model ExpenseTracker.Models.User

<div class="dashboard-box">

    <h2>My Profile</h2>

    <hr />

    <div class="row">

        <div class="col-md-6">

            <p>
                <strong>Full Name:</strong>
                @Model?.FullName
            </p>

            <p>
                <strong>Email:</strong>
                @Model?.Email
            </p>

            <p>
                <strong>Registered On:</strong>
                @Model?.CreatedDate.ToString("dd MMM yyyy")
            </p>

        </div>

    </div>

</div>
